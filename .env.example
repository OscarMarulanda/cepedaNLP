# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cepeda_nlp
DB_USER=oscarm
DB_PASSWORD=

# SSL (use "prefer" for localhost, "verify-full" for remote)
DB_SSLMODE=prefer
DB_SSLROOTCERT=

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Embedding provider: "local" (loads 868 MB model) or "hf_api" (zero RAM)
EMBEDDING_PROVIDER=local

# Required only when EMBEDDING_PROVIDER=hf_api
HF_TOKEN=hf_...
